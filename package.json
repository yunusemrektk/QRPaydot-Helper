{
  "name": "qrpaydot-helper",
  "version": "1.0.2",
  "private": true,
  "description": "QRPaydot Helper — local HTTP → RAW TCP (JetDirect) bridge for thermal printers. Merchant-Dash EXTERNAL mode.",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunusemrektk/QRPaydot-Helper.git"
  },
  "main": "electron-main.cjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "desktop": "electron .",
    "panel:install": "npm install --prefix panel",
    "panel:build": "npm run build --prefix panel",
    "panel:dev": "npm run dev --prefix panel",
    "build:win": "npm run panel:build && electron-builder --win --dir",
    "build:installer": "npm run panel:build && electron-builder --win nsis",
    "build:release:win": "npm run build:installer",
    "postinstall": "patch-package",
    "publish:win": "npm run panel:build && cross-env EP_DRAFT=false EP_PRE_RELEASE=false EP_GH_IGNORE_TIME=true dotenv -- electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.qrpaydot.helper",
    "productName": "QRPaydot Helper",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron-main.cjs",
      "src/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "installer/app-icon.png",
        "to": "app-icon.png"
      }
    ],
    "afterPack": "./scripts/afterPack.cjs",
    "publish": {
      "provider": "github",
      "owner": "yunusemrektk",
      "repo": "QRPaydot-Helper",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "installer/QRPaydotHelper.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "installer/QRPaydotHelper.ico",
      "uninstallerIcon": "installer/QRPaydotHelper.ico",
      "shortcutName": "QRPaydot Helper",
      "menuCategory": "QRPaydot",
      "include": "installer/nsis-extras.nsh",
      "artifactName": "QRPaydot.Helper.Setup.${ext}"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "iconv-lite": "^0.7.2",
    "undici": "^6.25.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "patch-package": "^8.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
